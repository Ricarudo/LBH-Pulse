PORT=3000
FRONTEND=http://localhost:4200

# Local development auth is currently handled by the Angular frontend.
# TODO: Add future Azure/Entra/JWT settings here after backend token validation is implemented.

# Existing MySQL runtime settings. Keep these while routes are still MySQL-backed.
DATABASE_HOST=localhost
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=testingpassword
MYSQL_DATABASE=KuoteSuite
MYSQL_PORT=3306

# PostgreSQL / Prisma migration settings. These are for the new parallel database layer.
DATABASE_URL=postgresql://kuotesuite:kuotesuite_dev_password@localhost:5432/kuotesuite?schema=public
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=kuotesuite
POSTGRES_PASSWORD=kuotesuite_dev_password
POSTGRES_DB=kuotesuite
