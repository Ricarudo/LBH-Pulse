generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

enum ItemType {
  PRODUCT
  LABOR
  SERVICE
}

enum ItemStatus {
  ACTIVE
  INACTIVE
}

enum ItemRelationType {
  KIT_COMPONENT
  RELATED
  REQUIRED
  OPTIONAL
}

model Request {
  id              String              @id @default(cuid())
  requestNumber   String              @unique
  title           String
  requestType     String
  source          String
  serviceCategory String
  status          String              @default("New")
  priority        String              @default("Normal")
  companyName     String?
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  siteName        String?
  siteAddress     String?
  city            String?
  state           String?
  clientId        String?
  contactId       String?
  siteId          String?
  assignedToId    String?
  currentStepId   String?
  receivedDate    DateTime            @default(now())
  dueDate         DateTime?
  nextAction      String?
  nextFollowUpAt  DateTime?
  lastActivityAt  DateTime?
  missingInfo     String?
  siteVisitNeeded Boolean             @default(false)
  siteVisitCompleted Boolean          @default(false)
  description     String?
  internalNotes   String?
  relatedQuoteId  String?
  checklistTemplateId String?
  checklistTemplateNameSnapshot String?
  createdById     String?
  archivedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  assignedTo      LocalUser?          @relation("AssignedRequests", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy       LocalUser?          @relation("CreatedRequests", fields: [createdById], references: [id], onDelete: SetNull)
  client          Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  contact         PointOfContact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  site            ClientSite?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  relatedQuote    Quote?              @relation(fields: [relatedQuoteId], references: [id], onDelete: SetNull)
  checklistTemplate RequestChecklistTemplate? @relation(fields: [checklistTemplateId], references: [id], onDelete: SetNull)
  activities      RequestActivity[]
  tasks           RequestTask[]
  notesList       RequestNote[]
  updates         RequestUpdate[]     @relation("RequestUpdates")
  collaborators   RequestCollaborator[]
  documents       LifecycleDocument[]
  checklistItems  RequestChecklistItem[]
  trades          RequestTrade[]
  checklistInstances RequestChecklistInstance[]

  @@index([status])
  @@index([priority])
  @@index([requestType])
  @@index([source])
  @@index([serviceCategory])
  @@index([assignedToId])
  @@index([currentStepId])
  @@index([clientId])
  @@index([contactId])
  @@index([siteId])
  @@index([relatedQuoteId])
  @@index([checklistTemplateId])
  @@index([archivedAt])
}

model RequestUpdate {
  id                    String           @id @default(cuid())
  requestId             String
  kind                  String
  title                 String?
  body                  String?
  authorId              String?
  authorNameSnapshot    String           @default("Pulse System")
  authorEmailSnapshot   String?
  authorRoleSnapshot    String?
  assigneeId            String?
  assigneeNameSnapshot  String?
  assigneeEmailSnapshot String?
  targetDate            DateTime?
  stepStatus            String?
  supersedesId          String?
  legacyTaskId          String?          @unique
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  request               Request          @relation("RequestUpdates", fields: [requestId], references: [id], onDelete: Cascade)
  author                LocalUser?       @relation("RequestUpdateAuthors", fields: [authorId], references: [id], onDelete: SetNull)
  assignee              LocalUser?       @relation("RequestUpdateAssignees", fields: [assigneeId], references: [id], onDelete: SetNull)
  supersedes            RequestUpdate?   @relation("RequestUpdateSupersession", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy          RequestUpdate[]  @relation("RequestUpdateSupersession")
  mentions              RequestUpdateMention[]

  @@index([requestId, createdAt])
  @@index([requestId, kind, stepStatus])
  @@index([assigneeId, stepStatus])
  @@index([supersedesId])
}

model RequestCollaborator {
  id        String   @id @default(cuid())
  requestId String
  userId    String
  addedById String?
  createdAt DateTime @default(now())
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user      LocalUser @relation("RequestCollaboratorUsers", fields: [userId], references: [id], onDelete: Cascade)
  addedBy   LocalUser? @relation("RequestCollaboratorAddedBy", fields: [addedById], references: [id], onDelete: SetNull)

  @@unique([requestId, userId])
  @@index([userId])
}

model RequestUpdateMention {
  id        String        @id @default(cuid())
  updateId  String
  userId    String
  readAt    DateTime?
  createdAt DateTime      @default(now())
  update    RequestUpdate @relation(fields: [updateId], references: [id], onDelete: Cascade)
  user      LocalUser     @relation("RequestUpdateMentions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([updateId, userId])
  @@index([userId, readAt])
}

model RequestChecklistTemplate {
  id              String                         @id @default(cuid())
  key             String                         @unique
  name            String
  requestType     String?
  serviceCategory String?
  active          Boolean                        @default(true)
  archivedAt      DateTime?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt
  items           RequestChecklistTemplateItem[]
  requests        Request[]
  requestInstances RequestChecklistInstance[]

  @@index([requestType])
  @@index([serviceCategory])
  @@index([active])
  @@index([archivedAt])
}

model RequestChecklistTemplateItem {
  id          String                   @id @default(cuid())
  templateId  String
  label       String
  description String?
  required    Boolean                  @default(true)
  appliesWhen String?
  sortOrder   Int                      @default(0)
  group       String?
  active      Boolean                  @default(true)
  template    RequestChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  requestItems RequestChecklistItem[]

  @@index([templateId])
  @@index([sortOrder])
  @@index([active])
}

model RequestChecklistItem {
  id             String                        @id @default(cuid())
  requestId      String
  templateItemId String?
  checklistInstanceId String?
  label          String
  description    String?
  required       Boolean                       @default(true)
  appliesWhen    String?
  sortOrder      Int                           @default(0)
  group          String?
  completed      Boolean                       @default(false)
  completedAt    DateTime?
  completedById  String?
  completedByNameSnapshot String?
  notes          String?
  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt
  request        Request                       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  templateItem   RequestChecklistTemplateItem? @relation(fields: [templateItemId], references: [id], onDelete: SetNull)
  checklistInstance RequestChecklistInstance?  @relation(fields: [checklistInstanceId], references: [id], onDelete: Cascade)
  completedBy    LocalUser?                    @relation(fields: [completedById], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@index([templateItemId])
  @@index([checklistInstanceId])
  @@index([completed])
  @@index([completedById])
}

model RequestTrade {
  id              String   @id @default(cuid())
  requestId       String
  serviceCategory String
  createdAt       DateTime @default(now())
  request         Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, serviceCategory])
  @@index([serviceCategory])
}

model RequestChecklistInstance {
  id                   String                    @id @default(cuid())
  requestId            String
  templateId           String?
  templateKeySnapshot  String
  templateNameSnapshot String
  matchType            String
  matchValue           String?
  active               Boolean                   @default(true)
  retiredAt            DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  request              Request                   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  template             RequestChecklistTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  items                RequestChecklistItem[]

  @@index([requestId])
  @@index([templateId])
  @@index([active])
  @@index([matchType, matchValue])
}

model RequestActivity {
  id        String   @id @default(cuid())
  requestId String
  type      String
  title     String
  body      String?
  actor     String   @default("Pulse User")
  createdAt DateTime @default(now())
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([createdAt])
}

model RequestTask {
  id          String    @id @default(cuid())
  requestId   String
  title       String
  dueAt       DateTime?
  owner       String    @default("Unassigned")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  request     Request   @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([completedAt])
}

model RequestNote {
  id        String   @id @default(cuid())
  requestId String
  body      String
  actor     String   @default("Pulse User")
  createdAt DateTime @default(now())
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([createdAt])
}

model LocalUser {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  role         String
  passwordHash String
  active       Boolean    @default(true)
  mustChangePassword Boolean @default(false)
  authProvider String     @default("LOCAL")
  themeMode    String     @default("system")
  accentTheme  String     @default("blue")
  motionMode   String     @default("luxurious")
  dashboardPreferences Json?
  entraObjectId String?
  lastLoginAt  DateTime?
  deactivatedAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  activities   Activity[]
  assignedRequests Request[] @relation("AssignedRequests")
  createdRequests  Request[] @relation("CreatedRequests")
  authoredRequestUpdates RequestUpdate[] @relation("RequestUpdateAuthors")
  assignedRequestUpdates RequestUpdate[] @relation("RequestUpdateAssignees")
  requestCollaborations RequestCollaborator[] @relation("RequestCollaboratorUsers")
  addedRequestCollaborators RequestCollaborator[] @relation("RequestCollaboratorAddedBy")
  requestUpdateMentions RequestUpdateMention[] @relation("RequestUpdateMentions")
  completedRequestChecklistItems RequestChecklistItem[]
  uploadedDocuments LifecycleDocument[] @relation("UploadedDocuments")
  accessRole   AccessRole @relation(fields: [role], references: [id], onDelete: Restrict)

  @@index([role])
  @@index([active])
  @@index([authProvider])
  @@index([entraObjectId])
  @@index([lastLoginAt])
}

model AccessRole {
  id             String           @id
  name           String
  normalizedName String           @unique
  color          String           @default("#64748B")
  systemKey      String?          @unique
  protected      Boolean          @default(false)
  archivedAt     DateTime?
  version        Int              @default(1)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  permissions    RolePermission[]
  users          LocalUser[]

  @@index([archivedAt])
  @@index([name])
}

model RolePermission {
  roleId     String
  permission String
  createdAt  DateTime   @default(now())
  role       AccessRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permission])
  @@index([permission])
}

model WorkspaceSettings {
  id           String   @id @default("default")
  name         String   @default("R2 Communications")
  timeZone     String   @default("America/Puerto_Rico")
  locale       String   @default("en-US")
  dateFormat   String   @default("MM/DD/YYYY")
  weekStartsOn Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Activity {
  id                String    @id @default(cuid())
  relatedEntityType String
  relatedEntityId   String
  actorUserId       String?
  actorName         String
  actorRole         String
  type              String
  title             String
  detail            String?
  metadata          Json?
  createdAt         DateTime  @default(now())
  actor             LocalUser? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([relatedEntityType, relatedEntityId])
  @@index([actorUserId])
  @@index([actorRole])
  @@index([type])
  @@index([createdAt])
}

model Opportunity {
  id          String    @id @default(cuid())
  number      String    @unique
  name        String
  clientName  String?
  status      String    @default("Open")
  owner       String    @default("Unassigned")
  value       Decimal   @default(0) @db.Decimal(12, 2)
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([owner])
  @@index([archivedAt])
}

model Quote {
  id          String    @id @default(cuid())
  quoteNumber String    @unique
  title       String
  clientId    String?
  clientName  String?
  status      String    @default("Draft")
  owner       String    @default("Unassigned")
  total       Decimal   @default(0) @db.Decimal(12, 2)
  sourceRequestIdSnapshot String?
  requestNumberSnapshot String?
  requestTitleSnapshot String?
  requestTypeSnapshot String?
  serviceCategorySnapshot String?
  contactNameSnapshot String?
  contactEmailSnapshot String?
  contactPhoneSnapshot String?
  siteNameSnapshot String?
  siteAddressSnapshot String?
  citySnapshot String?
  stateSnapshot String?
  scopeDescriptionSnapshot String?
  internalNotesSnapshot String?
  proposalNotes String?
  proposalPreparedAt DateTime?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  requests    Request[]
  project     Project?
  documents   LifecycleDocument[]
  items        QuoteItem[]

  @@index([status])
  @@index([owner])
  @@index([clientId])
  @@index([sourceRequestIdSnapshot])
  @@index([archivedAt])
}

model Item {
  id                 String             @id @default(cuid())
  name               String
  description        String?
  itemType           ItemType           @default(PRODUCT)
  status             ItemStatus         @default(ACTIVE)
  sku                String?
  partNumber         String?
  manufacturer       String?
  brand              String?
  category           String?
  subcategory        String?
  unitOfMeasure      String?
  cost               Decimal            @default(0) @db.Decimal(12, 2)
  sellPrice          Decimal            @default(0) @db.Decimal(12, 2)
  markupPercent      Decimal            @default(0) @db.Decimal(8, 2)
  taxable            Boolean            @default(true)
  primaryImageUrl    String?
  productUrl         String?
  datasheetUrl       String?
  internalNotes      String?
  quoteDescription   String?
  defaultLaborHours  Decimal            @default(0) @db.Decimal(8, 2)
  defaultLaborItemId String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  defaultLaborItem   Item?              @relation("DefaultLaborItem", fields: [defaultLaborItemId], references: [id], onDelete: SetNull)
  defaultLaborFor    Item[]             @relation("DefaultLaborItem")
  quoteItems         QuoteItem[]
  priceHistory       ItemPriceHistory[]
  outgoingRelations  ItemRelation[]     @relation("ItemRelationParent")
  incomingRelations  ItemRelation[]     @relation("ItemRelationChild")

  @@index([name])
  @@index([itemType])
  @@index([status])
  @@index([sku])
  @@index([partNumber])
  @@index([category])
  @@index([defaultLaborItemId])
}

model ItemPriceHistory {
  id                    String   @id @default(cuid())
  itemId                String
  previousCost          Decimal? @db.Decimal(12, 2)
  newCost               Decimal  @db.Decimal(12, 2)
  previousSellPrice     Decimal? @db.Decimal(12, 2)
  newSellPrice          Decimal  @db.Decimal(12, 2)
  changedAt             DateTime @default(now())
  item                  Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, changedAt])
}

model QuoteItem {
  id              String    @id @default(cuid())
  quoteId         String
  sourceItemId    String?
  section         String    @default("Materials")
  name            String
  description     String?
  itemType        ItemType
  sku             String?
  partNumber      String?
  manufacturer    String?
  brand           String?
  quantity        Decimal   @default(1) @db.Decimal(12, 3)
  unitOfMeasure   String?
  unitCost        Decimal   @default(0) @db.Decimal(12, 2)
  unitPrice       Decimal   @default(0) @db.Decimal(12, 2)
  markupPercent   Decimal   @default(0) @db.Decimal(8, 2)
  discountPercent Decimal   @default(0) @db.Decimal(5, 2)
  taxable         Boolean   @default(true)
  imageUrl        String?
  productUrl      String?
  lineSubtotal    Decimal   @default(0) @db.Decimal(12, 2)
  lineTax         Decimal   @default(0) @db.Decimal(12, 2)
  lineTotal       Decimal   @default(0) @db.Decimal(12, 2)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  quote           Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  sourceItem      Item?     @relation(fields: [sourceItemId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([sourceItemId])
  @@index([itemType])
  @@index([section])
  @@index([sortOrder])
}

model ItemRelation {
  id              String           @id @default(cuid())
  parentItemId    String
  childItemId     String
  relationType    ItemRelationType
  defaultQuantity Decimal          @default(1) @db.Decimal(12, 3)
  sortOrder       Int              @default(0)
  parentItem      Item             @relation("ItemRelationParent", fields: [parentItemId], references: [id], onDelete: Cascade)
  childItem       Item             @relation("ItemRelationChild", fields: [childItemId], references: [id], onDelete: Cascade)

  @@unique([parentItemId, childItemId, relationType])
  @@index([parentItemId])
  @@index([childItemId])
  @@index([relationType])
  @@index([sortOrder])
}

model Project {
  id            String    @id @default(cuid())
  projectNumber String    @unique
  title         String
  clientId      String
  quoteId       String?   @unique
  owner         String    @default("Unassigned")
  status        String    @default("Ready")
  budget        Decimal   @default(0) @db.Decimal(12, 2)
  startDate     DateTime?
  dueDate       DateTime?
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  quote         Quote?    @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  invoices      Invoice[]
  documents     LifecycleDocument[]

  @@index([clientId])
  @@index([status])
  @@index([owner])
  @@index([archivedAt])
}

model LifecycleDocument {
  id                 String    @id @default(cuid())
  requestId          String?
  quoteId            String?
  projectId          String?
  objectKey          String?   @unique
  originalFileName   String
  mediaType          String?
  byteSize           BigInt    @default(0)
  sha256             String?
  category           String    @default("Other")
  scanStatus         String    @default("Clean")
  scanMessage        String?
  scannedAt          DateTime?
  uploadedById       String?
  uploadedByName     String    @default("Pulse System")
  deletedAt          DateTime?
  deletedById        String?
  deletedByName      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  request            Request?  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  quote              Quote?    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  project            Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy         LocalUser? @relation("UploadedDocuments", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([requestId, deletedAt])
  @@index([quoteId, deletedAt])
  @@index([projectId, deletedAt])
  @@index([uploadedById])
  @@index([sha256])
  @@index([createdAt])
}

model Invoice {
  id            String    @id @default(cuid())
  invoiceNumber String    @unique
  title         String
  clientId      String
  projectId     String?
  owner         String    @default("Unassigned")
  status        String    @default("Draft")
  amount        Decimal   @default(0) @db.Decimal(12, 2)
  issuedDate    DateTime?
  dueDate       DateTime?
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([owner])
  @@index([archivedAt])
}

model Client {
  id                 String           @id @default(cuid())
  clientNumber       String           @unique
  companyName        String?
  legalName          String?
  displayName        String           @default("Unnamed Client")
  industry           String?
  website            String?
  status             String           @default("Active")
  accountOwner       String           @default("Unassigned")
  taxId              String?
  paymentTerms       String?
  preferredCurrency  String           @default("USD")
  preferredLanguage  String           @default("English")
  brandPreferences   String?
  technologyPreferences String?
  generalNotes       String?
  importantNotes     String?
  preferredVendors   String?
  preferredCameraBrand String?
  preferredAccessControlBrand String?
  preferredNetworkBrand String?
  preferredCablingBrand String?
  standardTechnologies String?
  documentationRequirements String?
  invoiceRequirements String?
  insuranceRequirements String?
  purchaseOrderRequired Boolean       @default(false)
  source             String?
  openOpportunities  Int              @default(0)
  activeProjects     Int              @default(0)
  lifetimeValue      Decimal          @default(0) @db.Decimal(12, 2)
  outstandingBalance Decimal          @default(0) @db.Decimal(12, 2)
  archivedAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  lastActivityAt     DateTime?
  contacts           PointOfContact[]
  sites              ClientSite[]
  services           ClientService[]
  activities         ClientActivity[]
  requests           Request[]
  quotes             Quote[]
  projects           Project[]
  invoices           Invoice[]

  @@index([status])
  @@index([accountOwner])
  @@index([archivedAt])
}

model PointOfContact {
  id                     String      @id @default(cuid())
  ownerType              String      @default("Client")
  ownerId                String
  clientId               String?
  siteId                 String?
  role                   String?     @default("Primary")
  name                   String?
  firstName              String      @default("Unknown")
  lastName               String      @default("")
  title                  String?
  department             String?
  email                  String?
  phone                  String?
  mobile                 String?
  preferredContactMethod String?
  isPrimary              Boolean     @default(false)
  isBilling              Boolean     @default(false)
  isPrimaryContact       Boolean     @default(false)
  isBillingContact       Boolean     @default(false)
  isTechnicalContact     Boolean     @default(false)
  isDecisionMaker        Boolean     @default(false)
  notes                  String?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  client                 Client?     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  site                   ClientSite? @relation(fields: [siteId], references: [id], onDelete: SetNull)
  requests               Request[]

  @@index([ownerType, ownerId])
  @@index([clientId])
  @@index([siteId])
  @@index([email])
}

model ClientSite {
  id                   String          @id @default(cuid())
  clientId             String
  name                 String?
  siteName             String          @default("Unnamed Site")
  siteType             String          @default("Main Office")
  address              String?
  addressLine1         String?
  addressLine2         String?
  city                 String?
  state                String?
  postalCode           String?
  country              String          @default("Puerto Rico")
  googleMapsUrl        String?
  latitude             Decimal?        @db.Decimal(10, 7)
  longitude            Decimal?        @db.Decimal(10, 7)
  operationalHours     String?
  accessInstructions   String?
  parkingInstructions  String?
  securityRequirements String?
  siteNotes            String?
  status               String?         @default("Active")
  isPrimarySite        Boolean         @default(false)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  client               Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contacts             PointOfContact[]
  requests             Request[]

  @@index([clientId])
  @@index([siteType])
  @@index([isPrimarySite])
}

model ClientService {
  id          String   @id @default(cuid())
  clientId    String
  serviceName String
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, serviceName])
  @@index([clientId])
}

model ClientActivity {
  id        String   @id @default(cuid())
  clientId  String
  type      String
  title     String
  detail    String?
  actor     String   @default("Pulse User")
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([createdAt])
}
