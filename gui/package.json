{
  "name": "gui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "cross-env NODE_OPTIONS=--openssl-legacy-provider ng serve --host 0.0.0.0",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider ng build",
    "watch": "cross-env NODE_OPTIONS=--openssl-legacy-provider ng build --watch --configuration development",
    "test": "ng test",
    "build:prod": "cross-env NODE_OPTIONS=--openssl-legacy-provider ng build --configuration production",
    "test:prod": "ng test --browsers=ChromeHeadless --watch=false --code-coverage"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~12.2.17",
    "@angular/cdk": "12.2.13",
    "@angular/common": "~12.2.17",
    "@angular/compiler": "~12.2.17",
    "@angular/core": "~12.2.17",
    "@angular/forms": "~12.2.17",
    "@angular/material": "12.2.13",
    "@angular/platform-browser": "~12.2.17",
    "@angular/platform-browser-dynamic": "~12.2.17",
    "@angular/router": "~12.2.17",
    "angular2-chartjs": "^0.5.1",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "ngx-filesaver": "^12.0.0",
    "pdf-lib": "^1.17.1",
    "rxjs": "~6.6.7",
    "tslib": "^2.8.1",
    "zone.js": "~0.11.8"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~12.2.18",
    "@angular/cli": "~12.2.18",
    "@angular/compiler-cli": "~12.2.17",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "~3.10.3",
    "@types/node": "^14.18.63",
    "cross-env": "^7.0.3",
    "jasmine-core": "~3.10.1",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~4.0.2",
    "karma-jasmine-html-reporter": "~1.7.0",
    "typescript": "~4.3.5"
  }
}
